@page "/fishermen/add"
@using FishClubAlginet.Blazor.Constants
@using FishClubAlginet.Contracts.Dtos.Requests.Fisherman
@using FishClubAlginet.Contracts.Enums
@inject HttpClient Http
@inject NavigationManager Nav
@inject NotificationService NotificationService

<PageTitle>Nuevo Pescador</PageTitle>

<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" class="mb-4">
    <RadzenIcon Icon="person_add" Style="font-size: 2rem;" />
    <RadzenText TextStyle="TextStyle.H4" TagName="TagName.H1" Style="margin: 0;">Nuevo Pescador</RadzenText>
</RadzenStack>

<RadzenCard class="w-100" Style="max-width: 900px;">
    <EditForm Model="@model" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <RadzenFieldset Text="Datos Personales" class="mb-4">
            <RadzenRow Gap="1rem" class="mb-3">
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Nombre *" Style="width: 100%;">
                        <RadzenTextBox @bind-Value="model.FirstName" Placeholder="Nombre" />
                    </RadzenFormField>
                    <ValidationMessage For="@(() => model.FirstName)" />
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Apellidos *" Style="width: 100%;">
                        <RadzenTextBox @bind-Value="model.LastName" Placeholder="Apellidos" />
                    </RadzenFormField>
                    <ValidationMessage For="@(() => model.LastName)" />
                </RadzenColumn>
            </RadzenRow>

            <RadzenRow Gap="1rem" class="mb-3">
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="Fecha de Nacimiento *" Style="width: 100%;">
                        <RadzenDatePicker @bind-Value="model.DateOfBirth" DateFormat="dd/MM/yyyy" Max="@DateTime.Today" />
                    </RadzenFormField>
                    <ValidationMessage For="@(() => model.DateOfBirth)" />
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="Tipo Documento *" Style="width: 100%;">
                        <RadzenDropDown @bind-Value="model.DocumentType" Data="@documentTypes"
                                        TextProperty="Text" ValueProperty="Value" />
                    </RadzenFormField>
                    <ValidationMessage For="@(() => model.DocumentType)" />
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="N. Documento *" Style="width: 100%;">
                        <RadzenTextBox @bind-Value="model.DocumentNumber" Placeholder="Numero de documento" />
                    </RadzenFormField>
                    <ValidationMessage For="@(() => model.DocumentNumber)" />
                </RadzenColumn>
            </RadzenRow>

            <RadzenRow Gap="1rem">
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Licencia Federativa" Style="width: 100%;">
                        <RadzenTextBox @bind-Value="model.FederationLicense" Placeholder="Opcional" />
                    </RadzenFormField>
                    <ValidationMessage For="@(() => model.FederationLicense)" />
                </RadzenColumn>
            </RadzenRow>
        </RadzenFieldset>

        <RadzenFieldset Text="Dirección" class="mb-4">
            <RadzenRow Gap="1rem" class="mb-3">
                <RadzenColumn Size="12" SizeMD="8">
                    <RadzenFormField Text="Calle" Style="width: 100%;">
                        <RadzenTextBox @bind-Value="model.AddressStreet" Placeholder="Calle" />
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="Ciudad" Style="width: 100%;">
                        <RadzenTextBox @bind-Value="model.AddressCity" Placeholder="Ciudad" />
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>

            <RadzenRow Gap="1rem">
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Codigo Postal" Style="width: 100%;">
                        <RadzenTextBox @bind-Value="model.AddressZipCode" Placeholder="Codigo Postal" />
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Provincia" Style="width: 100%;">
                        <RadzenTextBox @bind-Value="model.AddressProvince" Placeholder="Provincia" />
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>
        </RadzenFieldset>

        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" JustifyContent="JustifyContent.End">
            <RadzenButton Text="Cancelar" Icon="cancel" ButtonStyle="ButtonStyle.Light"
                          Click="@(() => Nav.NavigateTo("fishermen"))" />
            <RadzenButton ButtonType="ButtonType.Submit" Text="Guardar Pescador" Icon="save"
                          ButtonStyle="ButtonStyle.Primary" IsBusy="@isLoading" />
        </RadzenStack>
    </EditForm>
</RadzenCard>

@code {
    private CreateFishermanDto model = new();
    private bool isLoading;

    private readonly List<object> documentTypes = new()
    {
        new { Text = "DNI", Value = TypeNationalIdentifier.Dni },
        new { Text = "NIE", Value = TypeNationalIdentifier.Nie },
        new { Text = "Pasaporte", Value = TypeNationalIdentifier.Passport }
    };

    private async Task HandleSubmit()
    {
        isLoading = true;
        try
        {
            var response = await Http.PostAsJsonAsync(EndpointsConstants.Fishermen.Add, model);

            if (response.IsSuccessStatusCode)
            {
                NotificationService.Notify(NotificationSeverity.Success, "Pescador creado", "El pescador se ha registrado correctamente.");
                Nav.NavigateTo("fishermen");
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                NotificationService.Notify(NotificationSeverity.Error, "Error", $"No se pudo crear el pescador: {errorContent}");
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error de Conexion", ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }
}
