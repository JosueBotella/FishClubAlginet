@page "/fishermen/add"
@using FishClubAlginet.Contracts.Dtos.Requests.Fisherman
@using FishClubAlginet.Contracts.Enums
@inject HttpClient Http
@inject NavigationManager Nav
@inject NotificationService NotificationService

<PageTitle>@FishermanForm.PageTitle</PageTitle>

<RadzenText TextStyle="TextStyle.H4" TagName="TagName.H1" class="mb-4">@FishermanForm.PageTitle</RadzenText>

<RadzenCard class="w-100" Style="max-width: 800px;">
    <EditForm Model="@model" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />

        <RadzenText TextStyle="TextStyle.H6" class="mb-3">@FishermanForm.PersonalDataSection</RadzenText>

        <RadzenRow Gap="1rem" class="mb-3">
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">@FishermanForm.FirstNameLabel</RadzenText>
                <RadzenTextBox @bind-Value="model.FirstName" Placeholder="@FishermanForm.FirstNamePlaceholder" class="w-100" />
                <ValidationMessage For="@(() => model.FirstName)" />
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">@FishermanForm.LastNameLabel</RadzenText>
                <RadzenTextBox @bind-Value="model.LastName" Placeholder="@FishermanForm.LastNamePlaceholder" class="w-100" />
                <ValidationMessage For="@(() => model.LastName)" />
            </RadzenColumn>
        </RadzenRow>

        <RadzenRow Gap="1rem" class="mb-3">
            <RadzenColumn Size="12" SizeSM="6" SizeMD="4">
                <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">@FishermanForm.DateOfBirthLabel</RadzenText>
                <RadzenDatePicker @bind-Value="model.DateOfBirth" DateFormat="@Formats.ShortDate" class="w-100" Max="@DateTime.Today" />
                <ValidationMessage For="@(() => model.DateOfBirth)" />
            </RadzenColumn>
            <RadzenColumn Size="12" SizeSM="6" SizeMD="4">
                <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">@FishermanForm.DocumentTypeLabel</RadzenText>
                <RadzenDropDown @bind-Value="model.DocumentType" Data="@documentTypes"
                                TextProperty="Text" ValueProperty="Value" class="w-100" />
                <ValidationMessage For="@(() => model.DocumentType)" />
            </RadzenColumn>
            <RadzenColumn Size="12" SizeSM="12" SizeMD="4">
                <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">@FishermanForm.DocumentNumberLabel</RadzenText>
                <RadzenTextBox @bind-Value="model.DocumentNumber" Placeholder="@FishermanForm.DocumentNumberPlaceholder" class="w-100" />
                <ValidationMessage For="@(() => model.DocumentNumber)" />
            </RadzenColumn>
        </RadzenRow>

        <RadzenRow Gap="1rem" class="mb-4">
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">@FishermanForm.FederationLicenseLabel</RadzenText>
                <RadzenTextBox @bind-Value="model.FederationLicense" Placeholder="@FishermanForm.FederationLicensePlaceholder" class="w-100" />
                <ValidationMessage For="@(() => model.FederationLicense)" />
            </RadzenColumn>
        </RadzenRow>

        <RadzenText TextStyle="TextStyle.H6" class="mb-3">@FishermanForm.AddressSection</RadzenText>

        <RadzenRow Gap="1rem" class="mb-3">
            <RadzenColumn Size="12" SizeSM="8">
                <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">@FishermanForm.StreetLabel</RadzenText>
                <RadzenTextBox @bind-Value="model.AddressStreet" Placeholder="@FishermanForm.StreetPlaceholder" class="w-100" />
            </RadzenColumn>
            <RadzenColumn Size="12" SizeSM="4">
                <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">@FishermanForm.CityLabel</RadzenText>
                <RadzenTextBox @bind-Value="model.AddressCity" Placeholder="@FishermanForm.CityPlaceholder" class="w-100" />
            </RadzenColumn>
        </RadzenRow>

        <RadzenRow Gap="1rem" class="mb-4">
            <RadzenColumn Size="12" SizeSM="6">
                <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">@FishermanForm.ZipCodeLabel</RadzenText>
                <RadzenTextBox @bind-Value="model.AddressZipCode" Placeholder="@FishermanForm.ZipCodePlaceholder" class="w-100" />
            </RadzenColumn>
            <RadzenColumn Size="12" SizeSM="6">
                <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">@FishermanForm.ProvinceLabel</RadzenText>
                <RadzenTextBox @bind-Value="model.AddressProvince" Placeholder="@FishermanForm.ProvincePlaceholder" class="w-100" />
            </RadzenColumn>
        </RadzenRow>

        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" class="mt-4" Wrap="FlexWrap.Wrap">
            <RadzenButton ButtonType="ButtonType.Submit" Text="@FishermanForm.SaveButtonText" Icon="save"
                          ButtonStyle="ButtonStyle.Primary" IsBusy="@isLoading" />
            <RadzenButton Text="@FishermanForm.CancelButtonText" Icon="cancel" ButtonStyle="ButtonStyle.Light"
                          Click="@(() => Nav.NavigateTo(RoutesConstants.Home))" />
        </RadzenStack>
    </EditForm>
</RadzenCard>

@code {
    private CreateFishermanDto model = new();
    private bool isLoading;

    private static readonly List<object> documentTypes =
    [
        new { Text = DocumentTypeNames.Dni, Value = TypeNationalIdentifier.Dni },
        new { Text = DocumentTypeNames.Nie, Value = TypeNationalIdentifier.Nie },
        new { Text = DocumentTypeNames.Passport, Value = TypeNationalIdentifier.Passport }
    ];

    private async Task HandleSubmit()
    {
        isLoading = true;
        try
        {
            var response = await Http.PostAsJsonAsync(EndpointsConstants.Fishermen.Add, model);

            if (response.IsSuccessStatusCode)
            {
                NotificationService.Notify(NotificationSeverity.Success, FishermanForm.CreatedTitle, FishermanForm.CreatedMessage);
                Nav.NavigateTo(RoutesConstants.Home);
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                NotificationService.Notify(NotificationSeverity.Error, Notifications.ErrorTitle, $"{FishermanForm.CreateErrorPrefix}{errorContent}");
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, Notifications.ConnectionErrorTitle, ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }
}
