@page "/fishermen/add"
@attribute [Authorize(Roles = "Admin")]
@using FishClubAlginet.Contracts.Dtos.Requests.Fisherman
@using FishClubAlginet.Contracts.Enums
@inject HttpClient Http
@inject NavigationManager Nav
@inject NotificationService NotificationService

<PageTitle>@FishermanForm.PageTitle</PageTitle>

<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" class="mb-4">
    <RadzenIcon Icon="person_add" Style="font-size: 2rem;" />
    <RadzenText TextStyle="TextStyle.H4" TagName="TagName.H1" Style="margin: 0;">@FishermanForm.PageTitle</RadzenText>
</RadzenStack>

<RadzenCard class="w-100" Style="max-width: 900px;">
    <EditForm Model="@model" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <RadzenFieldset Text="@FishermanForm.PersonalDataSection" class="mb-4">
            <RadzenRow Gap="1rem" class="mb-3">
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="@FishermanForm.FirstNameLabel" Style="width: 100%;">
                        <RadzenTextBox @bind-Value="model.FirstName" Placeholder="@FishermanForm.FirstNamePlaceholder" />
                    </RadzenFormField>
                    <ValidationMessage For="@(() => model.FirstName)" />
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="@FishermanForm.LastNameLabel" Style="width: 100%;">
                        <RadzenTextBox @bind-Value="model.LastName" Placeholder="@FishermanForm.LastNamePlaceholder" />
                    </RadzenFormField>
                    <ValidationMessage For="@(() => model.LastName)" />
                </RadzenColumn>
            </RadzenRow>

            <RadzenRow Gap="1rem" class="mb-3">
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="@FishermanForm.DateOfBirthLabel" Style="width: 100%;">
                        <RadzenDatePicker @bind-Value="model.DateOfBirth" DateFormat="dd/MM/yyyy" Max="@DateTime.Today" />
                    </RadzenFormField>
                    <ValidationMessage For="@(() => model.DateOfBirth)" />
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="@FishermanForm.DocumentTypeLabel" Style="width: 100%;">
                        <RadzenDropDown @bind-Value="model.DocumentType" Data="@documentTypes"
                                        TextProperty="Text" ValueProperty="Value" />
                    </RadzenFormField>
                    <ValidationMessage For="@(() => model.DocumentType)" />
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="@FishermanForm.DocumentNumberLabel" Style="width: 100%;">
                        <RadzenTextBox @bind-Value="model.DocumentNumber" Placeholder="@FishermanForm.DocumentNumberPlaceholder" />
                    </RadzenFormField>
                    <ValidationMessage For="@(() => model.DocumentNumber)" />
                </RadzenColumn>
            </RadzenRow>

            <RadzenRow Gap="1rem">
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="@FishermanForm.FederationLicenseLabel" Style="width: 100%;">
                        <RadzenTextBox @bind-Value="model.FederationLicense" Placeholder="@FishermanForm.FederationLicensePlaceholder" />
                    </RadzenFormField>
                    <ValidationMessage For="@(() => model.FederationLicense)" />
                </RadzenColumn>
            </RadzenRow>
        </RadzenFieldset>

        <RadzenFieldset Text="@FishermanForm.AddressSection" class="mb-4">
            <RadzenRow Gap="1rem" class="mb-3">
                <RadzenColumn Size="12" SizeMD="8">
                    <RadzenFormField Text="@FishermanForm.StreetLabel" Style="width: 100%;">
                        <RadzenTextBox @bind-Value="model.AddressStreet" Placeholder="@FishermanForm.StreetPlaceholder" />
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="@FishermanForm.CityLabel" Style="width: 100%;">
                        <RadzenTextBox @bind-Value="model.AddressCity" Placeholder="@FishermanForm.CityPlaceholder" />
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>

            <RadzenRow Gap="1rem">
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="@FishermanForm.ZipCodeLabel" Style="width: 100%;">
                        <RadzenTextBox @bind-Value="model.AddressZipCode" Placeholder="@FishermanForm.ZipCodePlaceholder" />
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="@FishermanForm.ProvinceLabel" Style="width: 100%;">
                        <RadzenTextBox @bind-Value="model.AddressProvince" Placeholder="@FishermanForm.ProvincePlaceholder" />
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>
        </RadzenFieldset>

        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" JustifyContent="JustifyContent.End">
            <RadzenButton Text="@FishermanForm.CancelButtonText" Icon="cancel" ButtonStyle="ButtonStyle.Light"
                          Click="@(() => Nav.NavigateTo(RoutesConstants.AddFisherman.Replace("/add", string.Empty)))" />
            <RadzenButton ButtonType="ButtonType.Submit" Text="@FishermanForm.SaveButtonText" Icon="save"
                          ButtonStyle="ButtonStyle.Primary" IsBusy="@isLoading" />
        </RadzenStack>
    </EditForm>
</RadzenCard>

@code {
    private CreateFishermanDto model = new();
    private bool isLoading;

    private static readonly List<object> documentTypes =
    [
        new { Text = DocumentTypeNames.Dni, Value = TypeNationalIdentifier.Dni },
        new { Text = DocumentTypeNames.Nie, Value = TypeNationalIdentifier.Nie },
        new { Text = DocumentTypeNames.Passport, Value = TypeNationalIdentifier.Passport }
    ];

    private async Task HandleSubmit()
    {
        isLoading = true;
        try
        {
            var response = await Http.PostAsJsonAsync(EndpointsConstants.Fishermen.Add, model);

            if (response.IsSuccessStatusCode)
            {
                NotificationService.Notify(NotificationSeverity.Success,
                    FishermanForm.CreatedTitle, FishermanForm.CreatedMessage);
                Nav.NavigateTo(RoutesConstants.AddFisherman.Replace("/add", string.Empty));
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                NotificationService.Notify(NotificationSeverity.Error,
                    Notifications.ErrorTitle, $"{FishermanForm.CreateErrorPrefix}{errorContent}");
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, Notifications.ConnectionErrorTitle, ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }
}
