@page "/fishermen"
@attribute [Authorize(Roles = "Admin")]
@using FishClubAlginet.Blazor.Constants
@using FishClubAlginet.Contracts.Dtos.Common
@using FishClubAlginet.Contracts.Enums
@inject HttpClient Http
@inject NavigationManager Nav
@inject NotificationService NotificationService

<PageTitle>Fishermen</PageTitle>

<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
             JustifyContent="JustifyContent.SpaceBetween" class="mb-4">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
        <RadzenIcon Icon="groups" Style="font-size: 2rem;" />
        <RadzenText TextStyle="TextStyle.H4" TagName="TagName.H1" Style="margin: 0;">Fishermen</RadzenText>
    </RadzenStack>
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
        <RadzenTextBox @bind-Value="searchTerm"
                       Placeholder="@UIConstants.FishermanForm.SearchPlaceholder"
                       Style="width: 300px;"
                       @oninput="OnSearchInput" />
        <RadzenButton Text="New Fisherman" Icon="person_add" ButtonStyle="ButtonStyle.Primary"
                      Click="@(() => Nav.NavigateTo(RoutesConstants.AddFisherman))" />
    </RadzenStack>
</RadzenStack>

@if (hasError)
{
    <RadzenCard class="w-100">
        <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Center" Gap="1rem">
            <RadzenIcon Icon="error_outline" Style="font-size: 3rem; color: var(--rz-danger);" />
            <RadzenText TextStyle="TextStyle.H6">Failed to load fishermen</RadzenText>
            <RadzenText TextStyle="TextStyle.Body1">@errorMessage</RadzenText>
            <RadzenButton Text="Retry" Icon="refresh" ButtonStyle="ButtonStyle.Secondary"
                          Click="@(() => grid.Reload())" />
        </RadzenStack>
    </RadzenCard>
}
else
{
    <RadzenDataGrid @ref="grid" Data="@fishermen" TItem="FishermanRow" Count="@totalCount"
                    LoadData="@LoadData" IsLoading="@isLoading"
                    AllowPaging="true" PageSize="10"
                    AllowSorting="true"
                    PagerHorizontalAlign="HorizontalAlign.Center"
                    AllowColumnResize="true" Style="width: 100%;">
        <Columns>
            <RadzenDataGridColumn TItem="FishermanRow" Property="Id" Title="ID" Width="80px"
                                  TextAlign="TextAlign.Center" Visible="false" />
            <RadzenDataGridColumn TItem="FishermanRow" Property="FirstName" Title="First Name" />
            <RadzenDataGridColumn TItem="FishermanRow" Property="LastName" Title="Last Name" />
            <RadzenDataGridColumn TItem="FishermanRow" Property="DateOfBirth" Title="Date of Birth"
                                  FormatString="{0:dd/MM/yyyy}" Width="130px" />
            <RadzenDataGridColumn TItem="FishermanRow" Property="DocumentTypeName" Title="Doc. Type" Width="120px" />
            <RadzenDataGridColumn TItem="FishermanRow" Property="DocumentNumber" Title="Document No." />
            <RadzenDataGridColumn TItem="FishermanRow" Property="FederationLicense" Title="Fed. License" />
            <RadzenDataGridColumn TItem="FishermanRow" Property="AddressCity" Title="City" />
            <RadzenDataGridColumn TItem="FishermanRow" Property="AddressProvince" Title="Province" />
        </Columns>
    </RadzenDataGrid>
}

@code {
    private RadzenDataGrid<FishermanRow> grid = null!;
    private List<FishermanRow> fishermen = new();
    private int totalCount;
    private bool isLoading;
    private bool hasError;
    private string errorMessage = string.Empty;
    private string searchTerm = string.Empty;
    private System.Timers.Timer? debounceTimer;

    private async Task LoadData(LoadDataArgs args)
    {
        isLoading = true;
        hasError = false;
        errorMessage = string.Empty;

        try
        {
            var skip = args.Skip ?? 0;
            var take = args.Top ?? 10;
            var url = EndpointsConstants.Fishermen.GetAllPaged(skip, take, searchTerm);
            var response = await Http.GetAsync(url);

            if (!response.IsSuccessStatusCode)
            {
                hasError = true;
                errorMessage = $"Server responded with {(int)response.StatusCode} ({response.ReasonPhrase}).";
                return;
            }

            var result = await response.Content.ReadFromJsonAsync<PaginatedResult<FishermanResponse>>();

            fishermen = result?.Items.Select(f => new FishermanRow
            {
                Id = f.Id,
                FirstName = f.FirstName,
                LastName = f.LastName,
                DateOfBirth = f.DateOfBirth,
                DocumentType = f.DocumentType,
                DocumentNumber = f.DocumentNumber,
                FederationLicense = f.FederationLicense,
                AddressCity = f.AddressCity,
                AddressProvince = f.AddressProvince
            }).ToList() ?? new();

            totalCount = result?.TotalCount ?? 0;
        }
        catch (Exception ex)
        {
            hasError = true;
            errorMessage = ex.Message;
            NotificationService.Notify(NotificationSeverity.Error,
                UIConstants.Notifications.ErrorTitle,
                $"Could not load fishermen: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? string.Empty;

        debounceTimer?.Stop();
        debounceTimer?.Dispose();
        debounceTimer = new System.Timers.Timer(400);
        debounceTimer.Elapsed += async (_, _) =>
        {
            debounceTimer?.Stop();
            await InvokeAsync(async () => await grid.FirstPage(true));
        };
        debounceTimer.AutoReset = false;
        debounceTimer.Start();
    }

    public void Dispose()
    {
        debounceTimer?.Dispose();
    }

    private record FishermanResponse(
        int Id,
        string FirstName,
        string LastName,
        DateTime DateOfBirth,
        TypeNationalIdentifier DocumentType,
        string DocumentNumber,
        string? FederationLicense,
        string AddressCity,
        string AddressProvince
    );

    private class FishermanRow
    {
        public int Id { get; set; }
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public DateTime DateOfBirth { get; set; }
        public TypeNationalIdentifier DocumentType { get; set; }
        public string DocumentNumber { get; set; } = string.Empty;
        public string? FederationLicense { get; set; }
        public string AddressCity { get; set; } = string.Empty;
        public string AddressProvince { get; set; } = string.Empty;

        public string DocumentTypeName => DocumentType switch
        {
            TypeNationalIdentifier.Dni => UIConstants.DocumentTypeNames.Dni,
            TypeNationalIdentifier.Nie => UIConstants.DocumentTypeNames.Nie,
            TypeNationalIdentifier.Passport => UIConstants.DocumentTypeNames.Passport,
            _ => DocumentType.ToString()
        };
    }
}
