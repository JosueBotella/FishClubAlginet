@page "/change-password"
@inject HttpClient Http
@inject NotificationService NotificationService
@inject NavigationManager Nav

<PageTitle>@ChangePasswordPage.PageTitle</PageTitle>

<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" class="mb-4">
    <RadzenIcon Icon="lock" Style="font-size: 2rem;" />
    <RadzenText TextStyle="TextStyle.H4" TagName="TagName.H1" Style="margin: 0;">
        @ChangePasswordPage.PageTitle
    </RadzenText>
</RadzenStack>

<RadzenCard class="w-100" Style="max-width: 500px;">
    <RadzenTemplateForm TItem="ChangePasswordModel" Data="@model" Submit="OnSubmit">
        <RadzenStack Gap="1rem">
            <RadzenFormField Text="@ChangePasswordPage.CurrentPasswordLabel" Style="width: 100%;">
                <RadzenPassword @bind-Value="model.CurrentPassword"
                                Placeholder="@ChangePasswordPage.CurrentPasswordPlaceholder"
                                Name="CurrentPassword" />
            </RadzenFormField>
            <RadzenRequiredValidator Component="CurrentPassword" Text="Current password is required." />

            <RadzenFormField Text="@ChangePasswordPage.NewPasswordLabel" Style="width: 100%;">
                <RadzenPassword @bind-Value="model.NewPassword"
                                Placeholder="@ChangePasswordPage.NewPasswordPlaceholder"
                                Name="NewPassword" />
            </RadzenFormField>
            <RadzenRequiredValidator Component="NewPassword" Text="New password is required." />
            <RadzenLengthValidator Component="NewPassword" Min="6" Text="Password must be at least 6 characters." />

            <RadzenFormField Text="@ChangePasswordPage.ConfirmNewPasswordLabel" Style="width: 100%;">
                <RadzenPassword @bind-Value="model.ConfirmNewPassword"
                                Placeholder="@ChangePasswordPage.ConfirmNewPasswordPlaceholder"
                                Name="ConfirmNewPassword" />
            </RadzenFormField>
            <RadzenRequiredValidator Component="ConfirmNewPassword" Text="Please confirm your new password." />
            <RadzenCompareValidator Component="ConfirmNewPassword" Value="@model.NewPassword"
                                    Text="@ChangePasswordPage.PasswordMismatchError" />

            <RadzenButton Text="@ChangePasswordPage.SubmitButtonText"
                          ButtonType="ButtonType.Submit"
                          ButtonStyle="ButtonStyle.Primary"
                          Icon="lock"
                          IsBusy="@isSubmitting"
                          BusyText="Saving..." />
        </RadzenStack>
    </RadzenTemplateForm>
</RadzenCard>

@code {
    private ChangePasswordModel model = new();
    private bool isSubmitting;

    private async Task OnSubmit()
    {
        if (model.NewPassword != model.ConfirmNewPassword)
        {
            NotificationService.Notify(NotificationSeverity.Error,
                Notifications.ErrorTitle, ChangePasswordPage.PasswordMismatchError);
            return;
        }

        isSubmitting = true;

        try
        {
            var dto = new { model.CurrentPassword, model.NewPassword, model.ConfirmNewPassword };
            var response = await Http.PostAsJsonAsync(EndpointsConstants.Account.ChangePassword, dto);

            if (response.IsSuccessStatusCode)
            {
                NotificationService.Notify(NotificationSeverity.Success,
                    ChangePasswordPage.PasswordChangedTitle,
                    ChangePasswordPage.PasswordChangedMessage);
                model = new();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                NotificationService.Notify(NotificationSeverity.Error,
                    Notifications.ErrorTitle,
                    $"{ChangePasswordPage.PasswordChangeErrorPrefix}{response.ReasonPhrase}");
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error,
                Notifications.ConnectionErrorTitle, ex.Message);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private class ChangePasswordModel
    {
        public string CurrentPassword { get; set; } = string.Empty;
        public string NewPassword { get; set; } = string.Empty;
        public string ConfirmNewPassword { get; set; } = string.Empty;
    }
}
