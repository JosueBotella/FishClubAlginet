# =====================================================
# Variables de entorno para docker compose
# Copia este fichero a .env y rellena los valores reales.
# El .env real NO se commitea (está en .gitignore).
# =====================================================

# ----- SQL Server -----
# La password debe cumplir los requisitos de SQL Server:
#  - Mínimo 8 caracteres
#  - Combinar 3 de: mayúsculas, minúsculas, dígitos, símbolos
SA_PASSWORD=ChangeMe!StrongPassword123

# ----- JWT -----
# Genera una clave nueva (>=32 chars). Por ejemplo en bash:
#   openssl rand -base64 48
# O en PowerShell:
#   [Convert]::ToBase64String((1..48 | ForEach-Object {[byte](Get-Random -Max 256)}))
JWT_SECRET_KEY=replace-this-with-a-long-random-secret-min-32-chars
JWT_ISSUER=FishClubAlginetAPI
JWT_AUDIENCE=FishClubAlginetUsers
JWT_DURATION_MINUTES=60

# ----- Producción (solo docker-compose.prod.yml) -----
# Puerto público del frontend (Nginx). Cambia a 8080 si tienes otro proxy delante.
PUBLIC_HTTP_PORT=80
