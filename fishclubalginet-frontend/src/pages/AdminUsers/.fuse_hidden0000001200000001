import { useCallback, useEffect, useState } from 'react';
import {
  Container,
  Title,
  Table,
  Group,
  Badge,
  ActionIcon,
  TextInput,
  Button,
  Pagination,
  Text,
  Tooltip,
  Loader,
  Center,
  Alert,
} from '@mantine/core';
import {
  IconSearch,
  IconPlus,
  IconLock,
  IconLockOpen,
  IconRefresh,
} from '@tabler/icons-react';
import { notifications } from '@mantine/notifications';
import { useAuth } from '../../hooks';
import { getUsers, blockUser, unblockUser } from '../../api/usersApi';
import type { UserDto } from '../../types';
import CreateUserModal from './CreateUserModal';

const PAGE_SIZE = 15;

export default function AdminUsersPage() {
  const { user: currentUser } = useAuth();

  const [users, setUsers] = useState<UserDto[]>([]);
  const [totalCount, setTotalCount] = useState(0);
  const [page, setPage] = useState(1);
  const [search, setSearch] = useState('');
  const [searchInput, setSearchInput] = useState('');
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<string | null>(null);
  const [createModalOpen, setCreateModalOpen] = useState(false);

  const totalPages = Math.ceil(totalCount / PAGE_SIZE);

  const fetchUsers = useCallback(async () => {
    setLoading(true);
    setError(null);
    try {
      const skip = (page - 1) * PAGE_SIZE;
      const result = await getUsers(skip, PAGE_SIZE, search || undefined);
      setUsers(result.items);
      setTotalCount(result.totalCount);
    } catch {
      setError('Error al cargar los usuarios.');
    } finally {
      setLoading(false);
    }
  }, [page, search]);

  useEffect(() => {
    fetchUsers();
  }, [fetchUsers]);

  const handleSearch = () => {
    setPage(1);
    setSearch(searchInput);
  };

  const handleSearchKeyDown = (e: React.KeyboardEvent) => {
    if (e.key === 'Enter') handleSearch();
  };

  const handleToggleBlock = async (u: UserDto) => {
    try {
      if (u.isLockedOut) {
        await unblockUser(u.id);
        notifications.show({
          title: 'Usuario desbloqueado',
          message: u.email,
          color: 'green',
        });
      } else {
        await blockUser(u.id);
        notifications.show({
          title: 'Usuario bloqueado',
          message: u.email,
          color: 'orange',
        });
      }
      await fetchUsers();
    } catch {
      notifications.show({
        title: 'Error',
        message: 'No se pudo cambiar el estado del usuario.',
        color: 'red',
      });
    }
  };

  const handleUserCreated = () => {
    setCreateModalOpen(false);
    setPage(1);
    setSearch('');
    setSearchInput('');
    fetchUsers();
  };

  const isSelf = (u: UserDto) => u.id === currentUser?.id;

  return (
    <Container size="lg" py="md">
      <Group justify="space-between" mb="md">
        <Title order={3}>Gestion de usuarios</Title>
        <Button
          leftSection={<IconPlus size={18} />}
          onClick={() => setCreateModalOpen(true)}
        >
          Crear usuario
        </Button>
      </Group>

      {/* Barra de busqueda */}
      <Group mb="md">
        <TextInput
          placeholder="Buscar por email..."
          leftSection={<IconSearch size={16} />}
          value={searchInput}
          onChange={(e) => setSearchInput(e.currentTarget.value)}
          onKeyDown={handleSearchKeyDown}
          style={{ flex: 1 }}
        />
        <Button variant="light" onClick={handleSearch}>
          Buscar
        </Button>
        <ActionIcon
          variant="subtle"
          onClick={() => {
            setSearchInput('');
            setSearch('');
            setPage(1);
          }}
          title="Limpiar filtro"
        >
          <IconRefresh size={18} />
        </ActionIcon>
      </Group>

      {error && (
        <Alert color="red" mb="md">
          {error}
        </Alert>
      )}

      {loading ? (
        <Center py="xl">
          <Loader size="lg" />
        </Center>
      ) : users.length === 0 ? (
        <Text c="dimmed" ta="center" py="xl">
          No se encontraron usuarios.
        </Text>
      ) : (
        <>
          <Table striped highlightOnHover withTableBorder>
            <Table.Thead>
              <Table.Tr>
                <Table.Th>Email</Table.Th>
                <Table.Th>Roles</Table.Th>
                <Table.Th>Estado</Table.Th>
                <Table.Th style={{ width: 100 }}>Acciones</Table.Th>
              </Table.Tr>
            </Table.Thead>
            <Table.Tbody>
              {users.map((u) => (
                <Table.Tr key={u.id}>
                  <Table.Td>
                    <Text size="sm">
                      {u.email}
                      {isSelf(u) && (
                        <Text span c="dimmed" size="xs" ml="xs">
                          (tu)
                        </Text>
                      )}
                    </Text>
                  </Table.Td>
                  <Table.Td>
                    <Group gap={4}>
                      {u.roles.map((role) => (
                        <Badge
                          key={role}
                          size="sm"
                          variant="light"
                          color={role === 'Admin' ? 'blue' : 'teal'}
                        >
                          {role}
                        </Badge>
                      ))}
                    </Group>
                  </Table.Td>
                  <Table.Td>
                    <Badge
                      size="sm"
                      color={u.isLockedOut ? 'red' : 'green'}
                      variant="dot"
                    >
                      {u.isLockedOut ? 'Bloqueado' : 'Activo'}
                    </Badge>
                  </Table.Td>
                  <Table.Td>
                    <Tooltip
                      label={
                        isSelf(u)
                          ? 'No puedes bloquearte a ti mismo'
                          : u.isLockedOut
                            ? 'Desbloquear'
                            : 'Bloquear'
                      }
                    >
                      <ActionIcon
                        variant="subtle"
                        color={u.isLockedOut ? 'green' : 'red'}
                        onClick={() => handleToggleBlock(u)}
                        disabled={isSelf(u)}
                      >
                        {u.isLockedOut ? (
                          <IconLockOpen size={18} />
                        ) : (
                          <IconLock size={18} />
                        )}
                      </ActionIcon>
                    </Tooltip>
                  </Table.Td>
                </Table.Tr>
              ))}
            </Table.Tbody>
          </Table>

          {totalPages > 1 && (
            <Group justify="center" mt="md">
              <Pagination
                total={totalPages}
                value={page}
                onChange={setPage}
                size="sm"
              />
              <Text size="xs" c="dimmed">
                {totalCount} usuario{totalCount \!== 1 ? 's' : ''} en total
              </Text>
            </Group>
          )}
        </>
      )}

      <CreateUserModal
        opened={createModalOpen}
        onClose={() => setCreateModalOpen(false)}
        onCreated={handleUserCreated}
      />
    </Container>
  );
}
