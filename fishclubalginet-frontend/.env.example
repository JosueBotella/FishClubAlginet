# Variables del frontend (Vite)
# Solo las que empiezan por VITE_ se exponen al código del cliente.

# Si arrancas el front fuera de Docker contra Kestrel local con cert dev:
VITE_PROXY_TARGET=https://localhost:7179

# Si arrancas con docker compose, este valor lo sobreescribe el compose:
#   VITE_PROXY_TARGET=http://api:8080
